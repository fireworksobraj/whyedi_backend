{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article (Blog)",
    "description": "Blog posts with full SEO control"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "required": true
    },
    "content": {
      "type": "richtext"
    },
    "author": {
      "type": "string",
      "default": "Edi Shek"
    },
    "readTime": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "tags": {
      "type": "string"
    },
    "featuredImage": {
      "allowedTypes": ["images"],
      "type": "media",
      "multiple": false,
      "required": false
    },
    "metaTitle": {
      "type": "string"
    },
    "metaDescription": {
      "type": "text"
    },
    "canonicalUrl": {
      "type": "string"
    },
    "keywords": {
      "type": "string"
    },
    "ogTitle": {
      "type": "string"
    },
    "ogDescription": {
      "type": "text"
    },
    "ogImage": {
      "allowedTypes": ["images"],
      "type": "media",
      "multiple": false
    },
    "noIndex": {
      "type": "boolean",
      "default": false
    }
  }
}
